{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/share/([^/]+)$",
      "dest": "/api/share?id=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/assets/.*$",
      "status": 404
    },
    {
      "src": "^/fonts/.*$",
      "status": 404
    },
    {
      "src": "^/.*\\..*$",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
