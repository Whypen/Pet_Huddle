{
  "routes": [
    {
      "src": "^/share/([^/]+)$",
      "dest": "/api/share?id=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/assets/.*$",
      "status": 404
    },
    {
      "src": "^/fonts/.*$",
      "status": 404
    },
    {
      "src": "^/.*\\..*$",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
